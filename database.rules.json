{
  "rules": {
    ".read": false,
    ".write": false,
    "families": {
      "$familyCode": {
        ".read": true,
        "metadata": {
          ".read": true,
          ".write": "auth != null && !data.exists()",
          "createdAt": {
            ".validate": "newData.isNumber()"
          },
          "createdBy": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
          },
          "createdByUserId": {
            ".validate": "newData.isString() && newData.val().matches(/^user-[a-f0-9]{16}$/)"
          },
          "$other": {
            ".validate": false
          }
        },
        "members": {
          "$userId": {
            ".read": true,
            ".write": "auth != null && $userId.matches(/^user-[a-f0-9]{16}$/) && (((!data.exists()) && newData.child('userId').val() == $userId && newData.child('authUid').val() == auth.uid) || (data.exists() && data.child('authUid').val() == auth.uid))",
            "name": {
              ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
            },
            "userId": {
              ".validate": "newData.isString() && newData.val().matches(/^user-[a-f0-9]{16}$/)"
            },
            "authUid": {
              ".validate": "newData.isString() && auth != null && newData.val() == auth.uid"
            },
            "photoURL": {
              ".validate": "newData.isString() && newData.val().length <= 2000"
            },
            "favorites": {
              "$item": {
                ".validate": "newData.isString() && newData.val().length <= 200"
              }
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            },
            "lastSeen": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "writers": {
          ".read": false,
          "$authUid": {
            ".write": "auth != null && $authUid == auth.uid",
            ".validate": "newData.val() == true || !newData.exists()"
          }
        },
        "favoriteMeta": {
          ".read": true,
          ".write": "auth != null && root.child('families').child($familyCode).child('writers').child(auth.uid).val() == true",
          "$houseId": {
            ".validate": "newData.isString() || newData.hasChildren()",
            "$field": {
              ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
            }
          }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "houses": {
      ".read": "auth != null",
      ".indexOn": ["city"],
      "$houseId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['id'])",
        "$field": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren()"
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "settings": {
          "daysBack": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 90"
          },
          "searchArea": {
            ".validate": "newData.isString() && newData.val().length <= 100"
          },
          "viewMode": {
            ".validate": "newData.isString() && (newData.val() == 'browse' || newData.val() == 'swipe')"
          },
          "browseFilters": {
            "$field": {
              ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren() || !newData.exists()"
            }
          },
          "$other": {
            ".validate": false
          }
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
